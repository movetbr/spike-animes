# Firebase Admin SDK - Service Account (JSON string, uma linha)
# Gere em: Console Firebase → Configurações → Contas de serviço → Gerar nova chave privada
FIREBASE_SERVICE_ACCOUNT=

# API Key de proteção - qualquer string aleatória que você escolher
# O frontend DEVE enviar essa mesma key no header x-api-key
API_SECRET_KEY=sua-chave-secreta-aqui

# Porta do servidor (opcional)
PORT=3000
